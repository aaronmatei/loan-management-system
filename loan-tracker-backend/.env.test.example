# Copy to .env.test and fill in your local Postgres credentials.
# Tests run against an ISOLATED database (loan_tracker_test) so they never
# touch real data. Create it once with:
#   createdb loan_tracker_test
#   psql -d loan_tracker_test -f tests/setup/schema.sql
NODE_ENV=test
PORT=3001

DB_HOST=localhost
DB_PORT=5432
DB_NAME=loan_tracker_test
DB_USER=your_db_user
DB_PASSWORD=your_db_password

JWT_SECRET=test_secret_only_for_tests_minimum_32_characters_long
JWT_EXPIRE=7d

# Keep external integrations OFF in tests so no real messages are sent.
SMS_ENABLED=false
SMS_AUTO_CONFIRMATIONS=false
EMAIL_ENABLED=false
EMAIL_AUTO_CONFIRMATIONS=false
