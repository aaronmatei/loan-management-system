# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=loan_tracker
DB_USER=loan_user
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_key_minimum_32_characters
JWT_EXPIRE=7d

# Africastalking SMS (optional)
AFRICASTALKING_API_KEY=your_key_here
AFRICASTALKING_USERNAME=sandbox
SMS_ENABLED=false
SMS_SENDER_ID=AFRICASTKNG
SMS_AUTO_CONFIRMATIONS=true

# Email (Gmail / SMTP via Nodemailer) (optional)
# For Gmail: enable 2-Step Verification, then create an App Password
# (https://myaccount.google.com/apppasswords) and use it as EMAIL_PASSWORD.
EMAIL_ENABLED=false
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password
EMAIL_FROM_NAME=Your Company
EMAIL_FROM=your_email@gmail.com
EMAIL_AUTO_CONFIRMATIONS=true

# Admin
ADMIN_EMAIL=admin@yourcompany.com
COMPANY_NAME=Your Company
COMPANY_PHONE=0700000000
COMPANY_WEBSITE=www.yourcompany.com