# Copy to e2e/.env (gitignored) and set your local Postgres credentials.
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_db_user
DB_PASSWORD=your_db_password
E2E_DB_NAME=loan_tracker_e2e

# Only needed on OSes Playwright doesn't ship a browser build for (e.g. very
# new Ubuntu). Forces a compatible fallback build:
# PLAYWRIGHT_HOST_PLATFORM_OVERRIDE=ubuntu24.04-x64

# Optional: run the e2e servers on non-default ports so they don't clash with
# your running dev servers. Requires src/services/api.js to read VITE_API_URL.
# E2E_BACKEND_PORT=3100
# E2E_FRONTEND_PORT=5273
