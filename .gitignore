# Database
*.sql.backup
*.dump

# DB backups — full dumps contain client PII + password hashes.
# NOTE: scoped to the backups dir so migrations/*.sql stay tracked.
**/loan-tracker-backend/backups/

# Loose pre-migration safety dumps at the backend root (NOT under
# backups/, so the rule above misses them). Same PII/hash risk.
# Kept narrow so migrations/*.sql remain tracked.
backup_before_*.sql
**/loan-tracker-backend/backup_*.sql

# Marketing video footage — large binaries, kept out of git
marketing/*.webm
marketing/*.mp4
marketing/*.mov
record-demo.mjs
